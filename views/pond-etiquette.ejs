<%- include("partials/header.ejs") %>

	<main class="info-page-main">
		<section class="pond-notice" aria-labelledby="etiquette-title">
			<p class="notice-kicker">By order of the Very Damp Council</p>
			<h1 id="etiquette-title">Pond Etiquette</h1>
			<p class="notice-intro">A few gentle rules for keeping the reeds peaceful and the mud pleasantly squishy.
			</p>

			<ol class="pond-rules">
				<li><span>Croak respectfully.</span></li>
				<li><span>No splashing after moonrise.</span></li>
				<li><span>Do not lick mysterious frogs.</span></li>
				<li><span>Lily pads are first-come, first-served.</span></li>
				<li><span>Ducks have right of way.</span></li>
				<li><span>Whisper near sleeping tadpoles.</span></li>
				<li><span>Every pebble has feelings.</span></li>
				<li><span>Sitting quietly counts as a productive activity.</span></li>
				<li><span>If you find a crown, return it to the nearest suspicious toad.</span></li>
				<li><span>Leave enough mosquitoes for everyone.</span></li>
			</ol>

			<!-- <img class="notice-illustration" src="/images/bucket.png" alt="" /> -->
			<img class="cleaning-frog" src="/images/cleaning-frog.png" alt="A frog sweeping the pond" />
			<p class="notice-signoff">Thank you. The pond remembers kindness. It also remembers snacks.</p>
		</section>
	</main>

	<%- include("partials/footer.ejs") %>