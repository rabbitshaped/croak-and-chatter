<%- include("partials/header.ejs") %>

<main>
	<div class="pond-area">
		<div class="hero-band">
			<%- include("partials/hero.ejs") %>
		</div>

		<section class="comments-section" id="comments" aria-label="Pond chatter">
			<div class="comments-grid">
				<% comments.slice(0, 6).forEach((comment, index) => { %>
					<% if (comment === locals.commentToEdit) { %>
						<%- include("partials/editCommentCard.ejs", { comment, index }) %>
					<% } else { %>
						<%- include("partials/commentCard.ejs", { comment, index }) %>
					<% } %>
				<% }) %>
			</div>

			<div class="comment-carousel-controls" hidden>
				<button class="carousel-button carousel-button--previous" type="button" aria-label="Previous comment">
					<span aria-hidden="true">←</span>
				</button>
				<output class="carousel-status" aria-live="polite" aria-atomic="true">
					<span class="carousel-current">1</span> / <span class="carousel-total"><%= Math.min(comments.length, 6) %></span>
				</output>
				<button class="carousel-button carousel-button--next" type="button" aria-label="Next comment">
					<span aria-hidden="true">→</span>
				</button>
			</div>
		</section>
	</div>

	<%- include("partials/keepClean.ejs") %>
</main>

<%- include("partials/footer.ejs") %>
